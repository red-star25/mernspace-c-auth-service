{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "The user management service",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon --exec tsx src/server.ts",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --runInBand",
        "prepare": "husky",
        "start": "ts-node src/index.ts",
        "typeorm": "typeorm-ts-node-commonjs"
    },
    "author": "Dhruv Nakum",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/express-validator": "^2.20.33",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "bcrypt": "^6.0.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "http-errors": "^2.0.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "typeorm": "0.3.28",
        "winston": "^3.19.0"
    }
}
